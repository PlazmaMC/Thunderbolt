From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Alpha <dev@alpha93.kr>
Date: Sun, 25 Feb 2024 20:30:33 +0900
Subject: [PATCH] Implement Paper's new SectorFile


diff --git a/server.versions.toml b/server.versions.toml
index d8aed5742d2a31261084cab3e03a33d56e902fb0..92c26d0bb92eb9afef1bda90620e917480a31e39 100644
--- a/server.versions.toml
+++ b/server.versions.toml
@@ -1,4 +1,6 @@
 [versions]
+lz4 = "1.8.0" # Thunderbolt - SectorFile
+zstd = "1.5.5-11" # Thunderbolt - SectorFile
 ansi = "1.0.3"
 jansi = "3.21.0"
 rhino = "1.7.14"
@@ -15,6 +17,8 @@ configurate = "4.2.0-SNAPSHOT"
 terminal-appender = "1.3.0"
 
 [libraries]
+lz4 = { group = "org.lz4", name = "lz4-java", version.ref = "lz4" } # Thunderbolt - SectorFile
+zstd = { group = "com.github.luben", name = "zstd-jni", version.ref = "zstd" } # Thunderbolt - SectorFile
 ansi = { group = "net.kyori", name = "ansi", version.ref = "ansi" }
 mysql = { group = "com.mysql", name = "mysql-connector-j", version.ref = "mysql" }
 jansi = { group = "org.jline", name = "jline-terminal-jansi", version.ref = "jansi" }
@@ -36,3 +40,4 @@ terminal-appender = { group = "net.minecrell", name = "terminalconsoleappender",
 runtime = [ "sqlite", "mysql", "disruptor" ]
 implementation = [ "jansi", "terminal-appender", "ansi", "haproxy", "configurate", "mappingio", "rhino-engine", "rhino-runtime" ]
 test = [ "classgraph", "pioneer" ]
+sector = [ "lz4", "zstd" ] # Thunderbolt - SectorFile
